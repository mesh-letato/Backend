# 핀모아 로컬 환경변수 템플릿
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요. (.env 는 git에 커밋되지 않습니다)
#   cp .env.example .env
# 실행 전 셸에 로드:
#   export $(grep -v '^#' .env | xargs)

# ── 카카오 로컬 키워드 검색 (core-service, link-service 공통) ──
KAKAO_API_KEY=

# ── AWS Bedrock (link-service LLM 장소 추출) ──
# Bedrock API 키(베어러 토큰) 방식: 아래 한 줄만 채우면 됩니다. Access Key/Secret 불필요.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=ap-northeast-2
# 서울 리전에서 Sonnet 4.6 은 글로벌 교차 리전 추론(global. 접두사)을 사용합니다.
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6

# ── yt-dlp (link-service 동영상 메타데이터 추출) ──
# yt-dlp 가 PATH 에 없으면 절대 경로를 지정하세요. (예: /usr/local/bin/yt-dlp)
YTDLP_BINARY=yt-dlp
