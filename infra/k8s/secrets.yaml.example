# 이 파일을 참고해서 실제 시크릿을 kubectl 로 직접 생성하세요.
# 절대 실제 값을 채운 채로 커밋하지 마세요!
#
# 사용법:
#   kubectl create secret generic pinmoa-secrets \
#     --namespace pinmoa \
#     --from-literal=db-url="jdbc:postgresql://<RDS_HOST>:5432/pinmoa_dev" \
#     --from-literal=db-username="pinmoa" \
#     --from-literal=db-password="<YOUR_DB_PASSWORD>" \
#     --from-literal=jwt-secret="<YOUR_JWT_SECRET>"
#
# RDS_HOST 는 terraform output rds_endpoint 로 확인
#   terraform -chdir=infra/terraform output rds_endpoint

apiVersion: v1
kind: Secret
metadata:
  name: pinmoa-secrets
  namespace: pinmoa
type: Opaque
stringData:
  db-url: "jdbc:postgresql://<RDS_HOST>:5432/pinmoa_dev"
  db-username: "pinmoa"
  db-password: "<변경필수>"
  jwt-secret: "<변경필수_최소32자>"
